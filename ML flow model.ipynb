    "# ---------------------------------------------------------------------------\n",
    "# Train one Prophet model per material\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "all_forecasts = []\n",
    "print(\"Training Prophet models...\\n\")\n",
    "\n",
    "for material in FORECAST_MATERIALS:\n",
